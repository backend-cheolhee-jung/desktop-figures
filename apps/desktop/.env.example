# Tauri 앱 환경변수 예시
# 실제 값은 .env 파일에 작성 (gitignored)
# Vertex AI 토큰 같은 민감값은 런타임에 Tauri SecureStorage(OS 키체인)로 이동

VITE_AUTH_SERVER_URL=http://localhost:8080
VITE_SOCKET_SERVER_URL=ws://localhost:9090

# Vertex AI — 설정 화면에서 등록 가능 (추후 SecureStorage로 이관)
VITE_VERTEX_AI_TOKEN=your_vertex_ai_bearer_token
VITE_VERTEX_PROJECT_ID=your_gcp_project_id
VITE_VERTEX_LOCATION=us-central1
